# PulseWire env example — copy to .env.local and fill secrets

LLM_PROVIDER=xai
LLM_BASE_URL=https://api.x.ai/v1
LLM_API_KEY=
LLM_MODEL=grok-4.5
# 0 = raw RSS merge only (cheap). 1 = Grok polish per section + Brief (expensive).
LLM_SUMMARIZE=0
CACHE_TTL_MINUTES=10
RAW_CACHE_TTL_MINUTES=2
MAX_ITEMS_PER_SECTION=10

# Each X Pulse miss burns one x_search call. Keep low.
# M8 governor (preferred):
X_CALLS_DAILY_CAP=20
X_CALLS_COOLDOWN_MIN=30
X_MONTHLY_CAP=300
# Legacy alias (used if X_MONTHLY_CAP unset):
X_PULSE_MONTHLY_CAP=300

# SQLite history (M5 moat clock). Default: ./data/pulsewire.db
# PULSEWIRE_DB_PATH=
# Nightly VACUUM INTO snapshots (npm run backup:db)
# PULSEWIRE_BACKUP_DIR=

# Public beta door — required on any public URL. Leave unset for local-only.
# Visit /?key=<token> once to set the cookie. Gates refresh=1 + X deep-refresh.
# BETA_TOKEN=

# Playwright / fixture mode (set by test runner — do not enable on a public tunnel)
# PW_TEST=1
# PW_HISTORY=1
# PW_LLM_FAIL=1
# PW_FEEDS_DOWN=1
# RAW_CACHE_TTL_MS=300
