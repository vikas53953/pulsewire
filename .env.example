# PulseWire env example — copy to .env.local and fill secrets

LLM_PROVIDER=xai
LLM_BASE_URL=https://api.x.ai/v1
LLM_API_KEY=
LLM_MODEL=grok-4.5
CACHE_TTL_MINUTES=10
RAW_CACHE_TTL_MINUTES=2
MAX_ITEMS_PER_SECTION=10

X_PULSE_MONTHLY_CAP=60

# SQLite history (M5 moat clock). Default: ./data/pulsewire.db
# PULSEWIRE_DB_PATH=

# Playwright / fixture mode (set by test runner — do not enable in production)
# PW_TEST=1
# PW_HISTORY=1
# PW_LLM_FAIL=1
# PW_FEEDS_DOWN=1
# RAW_CACHE_TTL_MS=300
